{
    "nokia-conf:scope": "template",
    "nokia-conf:default-action": "drop",
    "nokia-conf:filter-name": "my-filter",
    "nokia-conf:entry": [
        {
            "description": "term-dport",
            "action": {
                "accept": [
                    null
                ]
            },
            "match": {
                "dst-port": {
                    "port": 53
                },
                "protocol": "tcp"
            },
            "entry-id": 10000
        }
    ]
}

