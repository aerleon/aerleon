rem Windows_advfirewall out Policy
rem this is an out test acl
rem
rem $Id:$
rem $Date:$
rem $Revision:$
rem inet
netsh advfirewall firewall add rule name=o_multi-proto enable=yes interfacetype=any dir=out localip=any remoteip=any protocol=tcp action=allow
netsh advfirewall firewall add rule name=o_multi-proto enable=yes interfacetype=any dir=out localip=any remoteip=any protocol=udp action=allow
netsh advfirewall firewall add rule name=o_multi-proto enable=yes interfacetype=any dir=out localip=any remoteip=any protocol=icmpv4 action=allow

